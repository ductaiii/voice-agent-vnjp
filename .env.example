PORT=8081
FRONTEND_ORIGIN=*

# Use ADC or point this to a service-account JSON that lives outside the repo.
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
GOOGLE_STT_LANGUAGE_CODE=vi-VN
GOOGLE_STT_ALTERNATIVE_LANGUAGE_CODES=
GOOGLE_STT_SAMPLE_RATE=44100
GOOGLE_STT_MODEL=latest_long

GOOGLE_TTS_LANGUAGE_CODE=vi-VN
GOOGLE_TTS_VOICE_NAME=vi-VN-Wavenet-A
GOOGLE_TTS_AUDIO_ENCODING=MP3

# Optional. If omitted, the backend derives a public base URL from the request.
PUBLIC_BASE_URL=

TTS_AUDIO_TTL_MS=1800000
TTS_CLEANUP_INTERVAL_MS=600000

DEEPL_AUTH_KEY=your-deepl-auth-key
DEEPL_SOURCE_LANGUAGE=VI
DEEPL_TARGET_LANGUAGE=JA

D_ID_AGENT_ID=your-d-id-agent-id
D_ID_CLIENT_KEY=your-d-id-client-key